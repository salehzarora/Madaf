# Madaf environment template — copy to `.env.local` (gitignored) and edit.
# No values in this file are production secrets; there IS no production
# Supabase project in this phase (local stack only).

# ── Data mode ────────────────────────────────────────────────────────────
# "mock" (default): UI reads from src/lib/mock/* — no backend needed.
# "supabase" (LOCAL DEV ONLY): the whole UI reads from the seeded local
#   database, AND writes are REAL — checkout inserts orders + status
#   changes persist (M3A), and admin can create/edit products,
#   inventory, manufacturers + logos and upload product images (M3B).
#   Requires SUPABASE_SERVICE_ROLE_KEY below and `npm run dev`
#   (production builds refuse this mode until M4 auth). `supabase db
#   reset` restores the clean demo data any time.
# Anything other than exactly "supabase" means mock.
NEXT_PUBLIC_MADAF_DATA_MODE=mock

# ── Local Supabase (see supabase/README.md) ──────────────────────────────
# Values are printed by `supabase start` / `supabase status`. The
# publishable key below is the CLI's shared LOCAL default — fine to commit,
# useless outside your machine. The URL must be LOCAL
# (127.0.0.1/localhost) — supabase data mode refuses hosted projects.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:55321
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH

# Server-only — BYPASSES Row Level Security; never reaches the browser.
# Required for supabase data mode (there is no auth yet, so dev reads AND
# writes run through a server-only, demo-tenant-scoped service client).
# Copy the "Secret" key from `supabase status`.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: which tenant the local-dev service context is pinned to
# (defaults to the seeded demo tenant).
#MADAF_SUPABASE_TENANT_ID=11111111-1111-4111-8111-111111111111
